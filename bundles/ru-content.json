{
  "schema": "srednoff-os.bundle.v1",
  "id": "ru-content",
  "version": "v2.1.2",
  "title": "RU Content Bundle",
  "default_enabled": false,
  "domains": ["ru-content", "content", "localization", "seo-ppc-growth"],
  "policy_gates": ["ru-data", "ru-marketplaces"],
  "recommended_skills": [
    "content-strategist-agent",
    "content-brief-keyword-map",
    "multilingual-content-localization-seo",
    "localization-i18n-engineering",
    "entity-knowledge-graph-seo",
    "content-design-microcopy"
