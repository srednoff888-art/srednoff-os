  "selector_hints": ["prefer_editorial_quality", "require_claim_review", "use_localization_review"],
  "validation_gates": ["editorial-review", "seo-brief-review", "claims-risk-review", "localization-review"],
  "blocked_without_confirmation": ["publish_regulated_claims", "publish_personal_data", "mass_generate_public_content"]
}

