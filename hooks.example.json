{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"$HOME\\.codex\\scripts\\srednoff-os-hook.ps1\" -Mode SessionStart",
            "timeout": 30,
            "statusMessage": "Srednoff OS v2.1.2 status check"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"$HOME\\.codex\\scripts\\srednoff-os-hook.ps1\" -Mode UserPromptSubmit",
            "timeout": 30,
            "statusMessage": "Srednoff OS v2.1.2 prompt preflight"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|shell_command|functions.shell_command|apply_patch|mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"$HOME\\.codex\\scripts\\srednoff-os-hook.ps1\" -Mode PreToolUse",
            "timeout": 30,
            "statusMessage": "Srednoff OS v2.1.2 tool preflight"
          }
        ]
      }
    ]
  }
}
